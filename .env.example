# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/personal_agents

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Nutritionix API (for food macro lookups)
NUTRITIONIX_APP_ID=your-nutritionix-app-id
NUTRITIONIX_API_KEY=your-nutritionix-api-key

# Telegram bot tokens (one per bot)
TELEGRAM_PODCAST_BOT_TOKEN=123456:ABC-DEF...
TELEGRAM_NUTRITION_BOT_TOKEN=123456:ABC-DEF...
TELEGRAM_SOCIAL_BOT_TOKEN=123456:ABC-DEF...

# Telegram webhook base URL (public HTTPS URL, e.g. from ngrok)
TELEGRAM_WEBHOOK_BASE_URL=https://your-ngrok-url.ngrok-free.app

# Your Telegram chat ID (for proactive bot messages)
OWNER_CHAT_ID=123456789

# Timezone for scheduled jobs
TIMEZONE=America/New_York

# Podcast settings
PODCAST_FEED_URLS=https://feeds.example.com/podcast1,https://feeds.example.com/podcast2
PODCAST_CHECK_INTERVAL_MINUTES=30

# Transcription
ASSEMBLYAI_API_KEY=your-assemblyai-key

# PodcastIndex (for resolving Spotify links to audio URLs)
PODCASTINDEX_API_KEY=your-podcastindex-api-key
PODCASTINDEX_API_SECRET=your-podcastindex-api-secret

# App settings
ENVIRONMENT=local
LOG_LEVEL=DEBUG
